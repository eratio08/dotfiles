{
  "layer": "top",
  "position": "top",
  "height": 30,
  // Choose the order of the modules
  "modules-left": [
    "tray",
    "network",
    "sway/window"
  ],
  "modules-center": [
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-right": [
    "temperature",
    "cpu",
    "memory",
    "backlight",
    "idle_inhibitor",
    "pulseaudio",
    "battery",
    "clock"
  ],
  // Modules configuration
  "sway/window": {
    "format": "[ {} ]",
    "max-length": 50
  },
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{index}: {icon}",
    "format-icons": {
      "1": "яДа",
      "2": "яЙй",
      "3": "яб╕",
      "4": "яб╕",
      "5": "яДб",
      "6": "яДб",
      "7": "яДа",
      "8": "яДа",
      "urgent": "яБк",
      "focused": "яЖТ",
      "default": "яДС"
    }
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>",
    "max-length": 50
  },
  "mpd": {
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) яАБ",
    "format-disconnected": "Disconnected яАБ",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
    "unknown-tag": "N/A",
    "interval": 2,
    "consume-icons": {
      "on": "яГД "
    },
    "random-icons": {
      "off": "<span color=\"#f53c3c\">яБ┤</span> ",
      "on": "яБ┤ "
    },
    "repeat-icons": {
      "on": "яАЮ "
    },
    "single-icons": {
      "on": "яАЮ1 "
    },
    "state-icons": {
      "paused": "яБМ",
      "playing": "яБЛ"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яБо",
      "deactivated": "яБ░"
    }
  },
  "tray": {
    "icon-size": 22,
    "spacing": 2
  },
  "clock": {
    "format": "{:%H:%M | %Y-%m-%d}",
    "tooltip-format": "{:%H:%M:%S}",
    "format-alt": "{:%H:%M | %d.%m.%Y}"
  },
  "cpu": {
    "interval": 3,
    "format": "{usage}% яЛЫ",
    "tooltip": true,
    "state": {
      "half": 50,
      "full": 85
    }
  },
  "memory": {
    "interval": 3,
    "format": "{}% яГЙ",
    "state": {
      "half": 50,
      "full": 85
    }
  },
  "temperature": {
    "interval": 3,
    "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
    "critical-threshold": 80,
    "tooltip": true,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": [
      "яЛЙ",
      "яЛЗ"
    ]
  },
  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [
      "яДС",
      "яЖЕ"
    ]
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ],
    "max-length": 25
  },
  "network": {
    "format-wifi": "яЗл {essid} {signalStrength}%",
    "format-ethernet": "яГБ {ifname}: {ipaddr}/{cidr}",
    "format-disconnected": "тЪа Disconnected",
    "interval": 10,
    "max-length": 50
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}яКФ",
    "format-muted": "яАж",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАз",
        "яАи"
      ]
    },
    "on-click": "pavucontrol"
  }
}