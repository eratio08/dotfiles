{
  "layer": "top", // Waybar at top layer
  // "position": "bottom", // Waybar position (top|bottom|left|right)
  "height": 30, // Waybar height (to be removed for auto height)
  // "width": 1280, // Waybar width
  // Choose the order of the modules
  "modules-left": [
    "tray",
    "network"
    // "sway/mode",
    // "custom/media"
    // "sway/window"
  ],
  "modules-center": [
    "sway/workspaces"
  ],
  "modules-right": [
    // "mpd",
    // "network",
    // "temperature",
    // "cpu",
    // "memory",
    "backlight",
    "idle_inhibitor",
    "pulseaudio",
    "battery",
    // "battery#bat2",
    "clock"
    // "tray"
  ],
  // Modules configuration
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{index}: {icon}",
    "format-icons": {
      "1": "яДа",
      "2": "яЙй",
      "3": "яб╕",
      "4": "яб╕",
      "5": "яДб",
      "6": "яДб",
      "7": "яДа",
      "8": "яДа",
      "urgent": "яБк",
      "focused": "яЖТ",
      "default": "яДС"
    }
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "mpd": {
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) яАБ",
    "format-disconnected": "Disconnected яАБ",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
    "unknown-tag": "N/A",
    "interval": 2,
    "consume-icons": {
      "on": "яГД "
    },
    "random-icons": {
      "off": "<span color=\"#f53c3c\">яБ┤</span> ",
      "on": "яБ┤ "
    },
    "repeat-icons": {
      "on": "яАЮ "
    },
    "single-icons": {
      "on": "яАЮ1 "
    },
    "state-icons": {
      "paused": "яБМ",
      "playing": "яБЛ"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яБо",
      "deactivated": "яБ░"
    }
  },
  "tray": {
    "icon-size": 22,
    "spacing": 2
  },
  "clock": {
    "format": "{:%H:%M | %Y-%m-%d}",
    "tooltip-format": "{:%H:%M:%S | %Y-%m-%d}",
    "format-alt": "{:%H:%M | %d.%m.%Y}"
  },
  "cpu": {
    "interval": 2,
    "format": "{usage}% яЛЫ",
    "tooltip": true,
    "state": {
      "half": 50,
      "full": 85
    }
  },
  "memory": {
    "interval": 10,
    "format": "{}% яГЙ",
    "state": {
      "half": 50,
      "full": 85
    }
  },
  "temperature": {
    // "thermal-zone": 1,
    "interval": 5,
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "critical-threshold": 80,
    // "format-critical": "{temperatureC}┬░C яЛЗ",
    "tooltip": true,
    "format": "{temperatureC}┬░C яЛЙ"
  },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{percent}% {icon}",
    "format-icons": [
      "яДС",
      "яЖЕ"
    ]
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ]
  },
  "battery#bat2": {
    "bat": "BAT2"
  },
  "network": {
    // "interface": "wlp2s0", // (Optional) To force the use of this interface
    "format-wifi": "яЗл{essid} {signalStrength}%",
    "format-ethernet": "яГБ{ifname}: {ipaddr}/{cidr}",
    "format-disconnected": "тЪа Disconnected",
    "interval": 10
  },
  "pulseaudio": {
    //"scroll-step": 1,
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}яКФ",
    "format-muted": "яАж",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАз",
        "яАи"
      ]
    },
    "on-click": "pavucontrol"
  }
  // "custom/media": {
  //   "format": "{icon} {}",
  //   "return-type": "json",
  //   "max-length": 40,
  //   "format-icons": {
  //     "spotify": "яЖ╝",
  //     "default": "ЁЯОЬ"
  //   },
  //   "escape": true,
  //   "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
  // }
}